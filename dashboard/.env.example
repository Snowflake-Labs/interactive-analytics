# Snowflake connection name from ~/.snowflake/connections.toml
CONNECTION_NAME=DEFAULT

# Cache externalbrowser SSO tokens between server restarts (default: on).
# Authenticate once in the browser; later restarts reuse ~/.snowflake/credential_cache/.
# SNOWFLAKE_CREDENTIAL_CACHE_DIR=~/.snowflake/credential_cache
# SNOWFLAKE_CLIENT_STORE_TEMPORARY_CREDENTIAL=false

# TPC-H benchmark database (created by tpc-h/setup)
# SNOWFLAKE_DATABASE=IW_TPCH_BENCH

# Default scale factor: 1, 10, 100, or 1000
DEFAULT_SCALE=10

# Or pass on the CLI: npm start -- --scale 100
# (npm start --scale 100 also works — bare scale number is accepted)

# Optional: explicit connection instead of CONNECTION_NAME
# SNOWFLAKE_ACCOUNT=your_account
# SNOWFLAKE_USER=your_user
# SNOWFLAKE_ROLE=SYSADMIN
# SNOWFLAKE_AUTHENTICATOR=externalbrowser
