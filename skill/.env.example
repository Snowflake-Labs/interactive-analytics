# Snowflake connection (use CONNECTION_NAME or explicit credentials)
CONNECTION_NAME=DEFAULT
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_ROLE=PUBLIC
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Database (shared between standard and interactive)
SNOWFLAKE_DATABASE=IW_TPCH_BENCH

# Standard warehouse and schema
STANDARD_WAREHOUSE=TPCH_BENCH_WH_100
STANDARD_SCHEMA=TPCH_SF100

# Interactive warehouse and schema
INTERACTIVE_WAREHOUSE=IW_TPCH_BENCH_WH_100
INTERACTIVE_SCHEMA=TPCH_SF100_IT
