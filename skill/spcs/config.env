# SPCS deployment configuration for the TPC-H benchmark API + locust load test.
# Sourced by every script under spcs/.  Edit values before running deploy.sh.

# --- Snowflake connection ---------------------------------------------------
# Must exist in `cortex connections list` and have SPCS privileges
# (create compute pool, create image repository, create service).
CONNECTION=PM

# Role used when running the deploy SQL. Must be able to create the objects
# below and own the resulting services.
ROLE=ACCOUNTADMIN

# Warehouse used for the deploy SQL session itself (not the runtime warehouse
# used by the dashboard queries — that one is picked per request).
DEPLOY_WAREHOUSE=COMPUTE_WH

# --- Object names -----------------------------------------------------------
DB=IW_TPCH_BENCH
SCHEMA=SPCS
IMAGE_REPO=IW_DASHBOARD_IMAGES
# API server serving the browser-facing dashboard UI + its /api/* calls.
DASHBOARD_SERVICE=DASHBOARD
# Second, isolated copy of the API server (same image) that Locust hits.
# Runs on LOCUST_COMPUTE_POOL so its load never competes with the dashboard.
LOCUST_API_SERVICE=DASHBOARD_API_LOCUST
# Locust load-generator service.
LOCUST_SERVICE=DASHBOARD_LOCUST

DASHBOARD_IMAGE=dashboard
LOCUST_IMAGE=dashboard-locust
IMAGE_TAG=latest

# --- Compute pools ----------------------------------------------------------
# The dashboard and locust services run on completely independent compute
# pools so they can be sized (and scaled) without affecting each other.
DASHBOARD_COMPUTE_POOL=IW_DASHBOARD_POOL
DASHBOARD_INSTANCE_FAMILY=CPU_X64_M
DASHBOARD_MIN_NODES=1
DASHBOARD_MAX_NODES=2

LOCUST_COMPUTE_POOL=IW_DASHBOARD_LOCUST_POOL
LOCUST_INSTANCE_FAMILY=CPU_X64_M
LOCUST_MIN_NODES=1
LOCUST_MAX_NODES=2

# --- Benchmark API runtime --------------------------------------------------
DASHBOARD_DATABASE=IW_TPCH_BENCH
DASHBOARD_PORT=3000

# Standard warehouse and schema
STANDARD_WAREHOUSE=TPCH_BENCH_WH_100
STANDARD_SCHEMA=TPCH_SF100

# Interactive warehouse and schema
INTERACTIVE_WAREHOUSE=IW_TPCH_BENCH_WH_100
INTERACTIVE_SCHEMA=TPCH_SF100_IT

# --- Locust runtime ---------------------------------------------------------
# Locust targets the isolated API server (LOCUST_API_SERVICE) — NOT the
# dashboard service — so the load test never contends with real user
# dashboard traffic.
# NOTE: SPCS internal DNS lowercases the service name AND converts every
# underscore to a hyphen (see docs: ECHO_SERVICE -> echo-service...).
# So DASHBOARD_API_LOCUST resolves as dashboard-api-locust.
LOCUST_HOST=http://dashboard-api-locust:3000
LOCUST_WEB_PORT=8089
LOCUST_USERS=10
LOCUST_SPAWN=5
# When LOCUST_HEADLESS=1 the container exits after LOCUST_RUN_TIME.
LOCUST_HEADLESS=0
LOCUST_RUN_TIME=5m
LOCUST_WAREHOUSE=both
